NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_DB_NAME=design_pipeline
# When true, MONGODB_URI is ignored; jobs are stored in process memory (lost on restart).
DISABLE_MONGODB=false

# Set to true for local testing without Docker/Redis (pipeline runs in-process; no retries via BullMQ).
DISABLE_REDIS=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Site root only (no /browse/...). Paytm Payments example:
JIRA_BASE_URL=https://paytmpayments.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

FIGMA_API_TOKEN=

BITBUCKET_USERNAME=you@company.com
BITBUCKET_API_TOKEN=
# Legacy alias (optional): if set without BITBUCKET_API_TOKEN, it is copied at startup.
# BITBUCKET_TOKEN=

BITBUCKET_DEFAULT_BRANCH=develop

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PIPELINE_MAX_ATTEMPTS=1

# DEPLOY_WEBHOOK_URL=https://example.com/hooks/deploy
