NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_DB_NAME=design_pipeline

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Site root only (no /browse/...). Paytm Payments example:
JIRA_BASE_URL=https://paytmpayments.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

FIGMA_API_TOKEN=

BITBUCKET_USERNAME=you@company.com
BITBUCKET_API_TOKEN=
# Legacy alias (optional): if set without BITBUCKET_API_TOKEN, it is copied at startup.
# BITBUCKET_TOKEN=

BITBUCKET_DEFAULT_BRANCH=develop

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PIPELINE_MAX_ATTEMPTS=1

# DEPLOY_WEBHOOK_URL=https://example.com/hooks/deploy
