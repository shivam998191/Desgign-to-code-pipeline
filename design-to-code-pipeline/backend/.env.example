NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB Atlas (or self-hosted). DB name can be omitted in URI if MONGODB_DB_NAME is set.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/
MONGODB_DB_NAME=design_pipeline

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

FIGMA_API_TOKEN=

GITHUB_TOKEN=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

PIPELINE_MAX_ATTEMPTS=1

# Optional: POST JSON payload for deploy/rollback hooks (no secrets in body)
# DEPLOY_WEBHOOK_URL=https://example.com/hooks/deploy
